pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                dir('complete') {
                    sh '''
                        chmod +x mvnw
                        ./mvnw clean package -DskipTests
                        ls -l target
                    '''
                }
            }
        }

        stage('Archive JAR') {
            steps {
                archiveArtifacts artifacts: 'complete/target/*.jar', fingerprint: true
            }
        }
    }

    post {
        success {
            echo 'Spring Boot jar built successfully.'
        }
        failure {
            echo 'Build failed.'
        }
    }
}
